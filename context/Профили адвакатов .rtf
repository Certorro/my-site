\u1072  \u1086 \u1090 \u1076 \u1077 \u1083 \u1077 \u1085 \u1080 \u1103  \u1074 \u1086 \u1089 \u1087 \u1080 \u1090 \u1072 \u1090 \u1077 \u1083 \u1100 \u1085 \u1086 \u1081  \u1088 \u1072 \u1073 \u1086 \u1090 \u1099  \u1086 \u1090 \u1076 \u1077 \u1083 \u1072  \u1084 \u1086 \u1088 \u1072 \u1083 \u1100 \u1085 \u1086 \'96\u1087 \u1089 \u1080 \u1093 \u1086 \u1083 \u1086 \u1075 \u1080 \u1095 \u1077 \u1089 \u1082 \u1086 \u1075 \u1086  \u1086 \u1073 \u1077 \u1089 \u1087 \u1077 \u1095 \u1077 \u1085 \u1080 \u1103  \u1041 \u1077 \u1083 \u1075 \u1086 \u1088 \u1086 \u1076 \u1089 \u1082 \u1086 \u1075 \u1086  \u1102 \u1088 \u1080 \u1076 \u1080 \u1095 \u1077 \u1089 \u1082 \u1086 \u1075 \u1086  \u1080 \u1085 \u1089 \u1090 \u1080 \u1090 \u1091 \u1090 \u1072  \u1052 \u1042 \u1044  \u1056 \u1086 \u1089 \u1089 \u1080 \u1080 . \u1047 \u1072  \u1076 \u1086 \u1073 \u1088 \u1086 \u1089 \u1086 \u1074 \u1077 \u1089 \u1090 \u1085 \u1086 \u1077  \u1080 \u1089 \u1087 \u1086 \u1083 \u1085 \u1077 \u1085 \u1080 \u1077  \u1089 \u1083 \u1091 \u1078 \u1077 \u1073 \u1085 \u1099 \u1093  \u1086 \u1073 \u1103 \u1079 \u1072 \u1085 \u1085 \u1086 \u1089 \u1090 \u1077 \u1081  \u1080  \u1074 \u1099 \u1089 \u1086 \u1082 \u1080 \u1081  \u1087 \u1088 \u1086 \u1092 \u1077 \u1089 \u1089 \u1080 \u1086 \u1085 \u1072 \u1083 \u1080 \u1079 \u1084  \u1087 \u1086 \u1086 \u1097 \u1088 \u1103 \u1083 \u1072 \u1089 \u1100  \u1088 \u1091 \u1082 \u1086 \u1074 \u1086 \u1076 \u1089 \u1090 \u1074 \u1086 \u1084  \u1076 \u1077 \u1085 \u1077 \u1078 \u1085 \u1086 \u1081  \u1087 \u1088 \u1077 \u1084 \u1080 \u1077 \u1081 . \
 \uc0\u1042 \u1089 \u1082 \u1086 \u1088 \u1077  \u1043 \u1086 \u1085 \u1090 \u1072 \u1088 \u1077 \u1085 \u1082 \u1086  \u1048 \u1074 \u1072 \u1085 \u1085 \u1072  \u1048 \u1074 \u1072 \u1085 \u1086 \u1074 \u1085 \u1072  \u1074 \u1085 \u1086 \u1074 \u1100  \u1073 \u1099 \u1083 \u1072  \u1087 \u1088 \u1080 \u1085 \u1103 \u1090 \u1072  \u1074  \u1095 \u1083 \u1077 \u1085 \u1099  \u1041 \u1077 \u1083 \u1075 \u1086 \u1088 \u1086 \u1076 \u1089 \u1082 \u1086 \u1081  \u1086 \u1073 \u1083 \u1072 \u1089 \u1090 \u1085 \u1086 \u1081  \u1082 \u1086 \u1083 \u1083 \u1077 \u1075 \u1080 \u1080  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1086 \u1074 , \u1090 \u1072 \u1082  \u1082 \u1072 \u1082  \u1077 \u1081  \u1091 \u1089 \u1087 \u1077 \u1096 \u1085 \u1086  \u1073 \u1099 \u1083  \u1089 \u1076 \u1072 \u1085  \u1082 \u1074 \u1072 \u1083 \u1080 \u1092 \u1080 \u1082 \u1072 \u1094 \u1080 \u1086 \u1085 \u1085 \u1099 \u1081  \u1101 \u1082 \u1079 \u1072 \u1084 \u1077 \u1085  \u1085 \u1072  \u1087 \u1088 \u1080 \u1089 \u1074 \u1086 \u1077 \u1085 \u1080 \u1077  \u1089 \u1090 \u1072 \u1090 \u1091 \u1089 \u1072  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1072 .\
\uc0\u1055 \u1086 \u1084 \u1080 \u1084 \u1086  \u1101 \u1090 \u1086 \u1075 \u1086 , \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090  \u1043 \u1086 \u1085 \u1090 \u1072 \u1088 \u1077 \u1085 \u1082 \u1086  \u1048 \u1074 \u1072 \u1085 \u1085 \u1072  \u1048 \u1074 \u1072 \u1085 \u1086 \u1074 \u1085 \u1072  \u1080 \u1084 \u1077 \u1077 \u1090  \u1089 \u1077 \u1088 \u1090 \u1080 \u1092 \u1080 \u1082 \u1072 \u1090 , \u1074 \u1099 \u1076 \u1072 \u1085 \u1085 \u1099 \u1081  \u1074  \u1087 \u1086 \u1076 \u1090 \u1074 \u1077 \u1088 \u1078 \u1076 \u1077 \u1085 \u1080 \u1077  \u1090 \u1086 \u1075 \u1086 , \u1095 \u1090 \u1086  \u1086 \u1085 \u1072   \u1087 \u1088 \u1080 \u1085 \u1103 \u1083 \u1072  \u1091 \u1095 \u1072 \u1089 \u1090 \u1080 \u1077  \u1074  \u1089 \u1077 \u1084 \u1080 \u1085 \u1072 \u1088 \u1077  \'ab\u1047 \u1072 \u1097 \u1080 \u1090 \u1072  \u1087 \u1088 \u1072 \u1074  \u1087 \u1086 \u1090 \u1077 \u1088 \u1087 \u1077 \u1074 \u1096 \u1080 \u1093  \u1086 \u1090  \u1087 \u1088 \u1077 \u1089 \u1090 \u1091 \u1087 \u1083 \u1077 \u1085 \u1080 \u1081 , \u1089 \u1086 \u1074 \u1077 \u1088 \u1096 \u1072 \u1077 \u1084 \u1099 \u1093  \u1074  \u1089 \u1092 \u1077 \u1088 \u1077  \u1074 \u1099 \u1089 \u1086 \u1082 \u1080 \u1093  \u1080 \u1085 \u1092 \u1086 \u1088 \u1084 \u1072 \u1094 \u1080 \u1086 \u1085 \u1085 \u1099 \u1093  \u1090 \u1077 \u1093 \u1085 \u1086 \u1083 \u1086 \u1075 \u1080 \u1081 \'bb, \u1086 \u1088 \u1075 \u1072 \u1085 \u1080 \u1079 \u1086 \u1074 \u1072 \u1085 \u1085 \u1099 \u1081  \u1040 \u1084 \u1077 \u1088 \u1080 \u1082 \u1072 \u1085 \u1089 \u1082 \u1086 \u1081  \u1040 \u1089 \u1089 \u1086 \u1094 \u1080 \u1072 \u1094 \u1080 \u1077 \u1081  \u1070 \u1088 \u1080 \u1089 \u1090 \u1086 \u1074  (ABA ROLI) \u1087 \u1088 \u1080  \u1091 \u1095 \u1072 \u1089 \u1090 \u1080 \u1080  \u1060 \u1077 \u1076 \u1077 \u1088 \u1072 \u1083 \u1100 \u1085 \u1086 \u1081  \u1087 \u1072 \u1083 \u1072 \u1090 \u1099  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1086 \u1074 , \u1089 \u1074 \u1080 \u1076 \u1077 \u1090 \u1077 \u1083 \u1100 \u1089 \u1090 \u1074 \u1086  \u1086  \u1090 \u1086 \u1084 , \u1095 \u1090 \u1086  \u1087 \u1088 \u1086 \u1096 \u1083 \u1072  \u1086 \u1073 \u1091 \u1095 \u1077 \u1085 \u1080 \u1077  \u1085 \u1072  \u1042 \u1099 \u1089 \u1096 \u1080 \u1093  \u1082 \u1091 \u1088 \u1089 \u1072 \u1093  \u1087 \u1086 \u1074 \u1099 \u1096 \u1077 \u1085 \u1080 \u1103  \u1082 \u1074 \u1072 \u1083 \u1080 \u1092 \u1080 \u1082 \u1072 \u1094 \u1080 \u1080  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1086 \u1074  \u1056 \u1086 \u1089 \u1089 \u1080 \u1081 \u1089 \u1082 \u1086 \u1081  \u1060 \u1077 \u1076 \u1077 \u1088 \u1072 \u1094 \u1080 \u1080  \u1087 \u1086  \u1087 \u1088 \u1086 \u1075 \u1088 \u1072 \u1084 \u1084 \u1077  \'ab\u1050 \u1086 \u1084 \u1087 \u1077 \u1090 \u1077 \u1085 \u1090 \u1085 \u1086 \u1089 \u1090 \u1100  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1072 \'bb, \u1089 \u1077 \u1088 \u1090 \u1080 \u1092 \u1080 \u1082 \u1072 \u1090 , \u1074 \u1099 \u1076 \u1072 \u1085 \u1085 \u1099 \u1081  \u1074  \u1087 \u1086 \u1076 \u1090 \u1074 \u1077 \u1088 \u1078 \u1076 \u1077 \u1085 \u1080 \u1077  \u1090 \u1086 \u1075 \u1086 , \u1095 \u1090 \u1086  \u1086 \u1085 \u1072  \u1087 \u1088 \u1086 \u1096 \u1083 \u1072  \u1086 \u1073 \u1091 \u1095 \u1077 \u1085 \u1080 \u1077  \u1087 \u1086  \u1082 \u1091 \u1088 \u1089 \u1091  \'ab\u1050 \u1086 \u1084 \u1087 \u1077 \u1090 \u1077 \u1085 \u1090 \u1085 \u1086 \u1089 \u1090 \u1100  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1072 \'bb, \u1086 \u1088 \u1075 \u1072 \u1085 \u1080 \u1079 \u1086 \u1074 \u1072 \u1085 \u1085 \u1086 \u1084 \u1091  \u1060 \u1077 \u1076 \u1077 \u1088 \u1072 \u1083 \u1100 \u1085 \u1086 \u1081  \u1087 \u1072 \u1083 \u1072 \u1090 \u1086 \u1081  \u1072 \u1076 \u1074 \u1086 \u1082 \u1072 \u1090 \u1086 \u1074  \u1056 \u1060  \u1080  \u1062 \u1077 \u1085 \u1090 \u1088 \u1086 \u1084  \u1087 \u1088 \u1072 \u1074 \u1086 \u1074 \u1099 \u1093  \u1080 \u1089 \u1089 \